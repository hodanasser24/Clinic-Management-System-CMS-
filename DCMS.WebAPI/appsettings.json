{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://localhost:3000",
    "https://clinic.example.com"
  ],
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=DCMS;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "DCMS",
    "Audience": "DCMSClients",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 7
  },
  "Email": {
    "SmtpHost": "smtp.example.com",
    "SmtpPort": 587,
    "UseSsl": true,
    "Username": "noreply@clinic.example.com",
    "Password": "REPLACE_WITH_EMAIL_PASSWORD",
    "FromName": "Dental Clinic",
    "FromAddress": "noreply@clinic.example.com"
  },
  "Hangfire": {
    "DashboardPath": "/hangfire"
  }
}
